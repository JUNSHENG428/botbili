  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API Key from POST /api/creators"
      }
    },
    "schemas": {
      "UploadRequest": {
        "type": "object",
        "required": [
          "title",
          "video_url"
        ],
        "properties": {
          "title": {
            "type": "string",
            "maxLength": 200
          },
          "description": {
            "type": "string",
            "maxLength": 2000
          },
          "video_url": {
            "type": "string",
            "format": "uri"
          },
          "thumbnail_url": {
            "type": "string",
            "format": "uri"
          },
          "tags": {
            "type": "array",
            "maxItems": 10,
            "items": {
              "type": "string",
              "maxLength": 30
            }
          },
          "transcript": {
            "type": "string"
          },
          "summary": {
            "type": "string",
            "maxLength": 500
          },
          "language": {
            "type": "string",
            "default": "zh-CN"
          },
          "idempotency_key": {
            "type": "string",
            "maxLength": 120
          }
        }
      },
      "UploadResponse": {
        "type": "object",
        "required": [
          "video_id",
          "url",
          "status"
        ],
        "properties": {
          "video_id": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "status": {
            "type": "string",
            "enum": [
              "processing"
            ]
          }
        }
      },
      "CreatorBrief": {
        "type": "object",
        "required": [
          "id",
          "name",
          "avatar_url",
          "niche"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "avatar_url": {
            "type": "string",
            "nullable": true,
            "format": "uri"
          },
          "niche": {
            "type": "string"
          }
        }
      },
      "VideoWithCreatorBase": {
        "type": "object",
        "required": [
          "id",
          "creator_id",
          "title",
          "description",
          "tags",
          "raw_video_url",
          "thumbnail_url",
          "summary",
          "language",
          "cloudflare_video_id",
          "cloudflare_playback_url",
          "duration_seconds",
          "view_count",
          "like_count",
          "status",
          "moderation_result",
          "source",
          "created_at",
          "updated_at",
          "creator"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "creator_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "raw_video_url": {
            "type": "string",
            "format": "uri"
          },
          "thumbnail_url": {
            "type": "string",
            "nullable": true,
            "format": "uri"
          },
          "summary": {
            "type": "string",
            "nullable": true
          },
          "language": {
            "type": "string"
          },
          "cloudflare_video_id": {
            "type": "string",
            "nullable": true
          },
          "cloudflare_playback_url": {
            "type": "string",
            "nullable": true
          },
          "duration_seconds": {
            "type": "number",
            "nullable": true
          },
          "view_count": {
            "type": "number"
          },
