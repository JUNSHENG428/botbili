NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cookie 加密密钥（必须为 32 字节随机字符串）
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_ENCRYPTION_KEY=

WECHAT_TOKEN=

OPENAI_API_KEY=

APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
DAILY_AGENT_LIMIT=20
ADMIN_EMAIL=majunsheng0428@gmail.com

# ─── Recipe 执行 ──────────────────────────────────
# mock 模式（本地开发默认）：true
# 真实执行模式：false（用户需在本地运行 openclaw CLI）
USE_MOCK_EXECUTION=true

# openclaw CLI 回调验签密钥（botbili 自己生成，填任意随机字符串）
# openclaw CLI 在 POST /api/executions/{id}/callback 时需带上此值
# Header: X-BotBili-Callback-Secret: <此值>
OPENCLAW_CALLBACK_SECRET=your-random-secret-here
