NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cookie 加密密钥（必须为 32 字节随机字符串）
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_ENCRYPTION_KEY=

WECHAT_TOKEN=

OPENAI_API_KEY=

APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
DAILY_AGENT_LIMIT=20
ADMIN_EMAIL=majunsheng0428@gmail.com

# Recipe execution driver
# - mock: 本进程内模拟执行（默认）
# - openclaw: 转发给外部 OpenClaw 执行器，再由 callback 回写状态
# 设置为 false 启用真实 OpenClaw 调用
USE_MOCK_EXECUTION=true
OPENCLAW_EXECUTE_URL=
OPENCLAW_API_KEY=
OPENCLAW_CALLBACK_SECRET=
